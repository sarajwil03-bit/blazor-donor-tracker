@page "/Donations"
@using Radzen
@using Radzen.Blazor 
@using NonProfitDB_Wilkinson.Models
@inject NonProfitDBContext _dbContext
@inject NotificationService NotificationService
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore


<RadzenCard Style="margin:20px; padding:20px; background:white; border-radius:6px;">
    <h3>Donations</h3>
<RadzenDataGrid @ref="_donationGrid" AllowAlternatingRows="false" AllowFiltering="true" AllowPaging="true" PageSize="5" AllowSorting="true" EditMode="@DataGridEditMode.Single"
                Data="@_donations" TItem="Donation" RowUpdate="@OnUpdateRow" RowCreate="@OnCreateRow" Sort="@Reset" Page="@Reset" Filter="@Reset" ColumnWidth="200px">
    <HeaderTemplate>
        <RadzenButton ButtonStyle="ButtonStyle.Success" Icon="add_circle" Text="Add Donations" Click="@InsertRow" Disabled="@( DonationToInsert.Count() > 0)" />
    </HeaderTemplate>
    <Columns>
        <RadzenDataGridColumn Title="Donor" Width="200px">
                @*displays the full name of the donor in the first column instead of the id after submitting a donation*@
                <Template Context="_donation"> 
                    @_donorInfo.FirstOrDefault(d => d.Id == _donation.DonorId)?.FullName</Template>
               <EditTemplate Context="_donation">
                    <RadzenDropDown @bind-Value=@_donation.DonorId Data=@_donorInfo TextProperty="@nameof(DonorInfo.FullName)" ValueProperty="@nameof(DonorInfo.Id)" Style="width: 100%" Name="DonorId" />
                </EditTemplate>
        </RadzenDataGridColumn>
            <RadzenDataGridColumn Title="Category" Width="200px">
                <Template Context="_donation">
                    @*displays the name of the categories that have been submitted*@
                    @_categoryInfo.FirstOrDefault(c => c.Id == _donation.DonationCategoryId)?.Name</Template>
                <EditTemplate Context="_donation">
                    <RadzenDropDown @bind-Value=@_donation.DonationCategoryId Data=@_categoryInfo TextProperty="@nameof(CategoryInfo.Name)" ValueProperty="@nameof(CategoryInfo.Id)" Style="width: 100%" Name="DonationCategoryId" />
                </EditTemplate>
        </RadzenDataGridColumn>
        <RadzenDataGridColumn Property="DonationDate" Title="Donation Date" Width="200px">
            <EditTemplate Context="_donation">
                    <RadzenDatePicker @bind-Value="_donation.DonationDate" Name="DonationDate" Style="width:150px; display: block" aria-label="Enter Date"  />
                    <RadzenRequiredValidator Text="Donation Date is required" Component="DonationDate" Popup="true" />
            </EditTemplate>
        </RadzenDataGridColumn>
            <RadzenDataGridColumn Property="EntryDate" Title="Entry date" Width="200px">
                <EditTemplate Context="_donation">
                    <RadzenDatePicker @bind-Value="_donation.EntryDate" Style="width:150px; display: block" Name="EntryDate" aria-label="Enter Entry Date" Popup="true" />
                    <RadzenRequiredValidator Text="Entry Date is required" Component="EntryDate" Popup="true" />
                </EditTemplate>
            </RadzenDataGridColumn>
            @*Taken from the Radzen Blazor component website from the InLineEditing source code to make the '$' appear in the result*@
       <RadzenDataGridColumn Property="@nameof(_donation.Amount)" Title="Amount">
            <Template Context="_donation">
                @String.Format(new System.Globalization.CultureInfo("en-US"), "{0:C}", _donation.Amount)
            </Template>
            <EditTemplate Context="_donation">
                <RadzenNumeric @bind-Value="_donation.Amount" Style="width:100%" InputAttributes="@(new Dictionary<string,object>(){ { "aria-label", "Select amount" }})" />
            </EditTemplate>
        </RadzenDataGridColumn>
        <RadzenDataGridColumn Property="PaymentMethod" Title="Payment method" Width="200px">
                <EditTemplate Context="_donation">
                    <RadzenTextBox @bind-Value="_donation.PaymentMethod" Style="width:150px; display: block" Name="PaymentMethod" aria-label="Enter Payment method" />
                    <RadzenRequiredValidator Text="Payment Method is required" Component="PaymentMethod" Popup="true" />
                </EditTemplate>
            </RadzenDataGridColumn>
        <RadzenDataGridColumn Property="ReferenceNumber" Title="Reference Number" Width="200px">
                <EditTemplate Context="_donation">
                    <RadzenTextBox @bind-Value="_donation.ReferenceNumber" Style="width:150px; display: block" Name="ReferenceNumber" aria-label="Enter Reference Number" />
                    <RadzenRequiredValidator Text="Reference Number is required" Component="ReferenceNumber" Popup="true" />
                </EditTemplate>
            </RadzenDataGridColumn>
        <RadzenDataGridColumn Property="Notes" Title="Notes" Width="200px">
                <EditTemplate Context="_donation">
                    <RadzenTextBox @bind-Value="_donation.Notes" Style="width:150px; display: block" Name="Notes" aria-label="Enter any Notes" />
                    <RadzenRequiredValidator Text="Notes is required" Component="Notes" Popup="true" />
                </EditTemplate>
            </RadzenDataGridColumn>
        <RadzenDataGridColumn Property="RecordedBy" Title="Recorded By" Width="200px">
                <EditTemplate Context="_donation">
                    <RadzenTextBox @bind-Value="_donation.RecordedBy" Style="width:150px; display: block" Name="RecordedBy" aria-label="Enter a Recorded By" />
                    <RadzenRequiredValidator Text="Recorded By is required" Component="RecordedBy" Popup="true" />
                </EditTemplate>
            </RadzenDataGridColumn>
        <RadzenDataGridColumn Context="_donation" Filterable="false" Sortable="false" TextAlign="TextAlign.Right" Frozen="true" FrozenPosition="FrozenColumnPosition.Right">
            <Template Context="_donation">
                <RadzenButton Icon="edit" ButtonStyle="ButtonStyle.Light" Variant="Variant.Flat" Size="ButtonSize.Medium" class="rz-my-1 rz-ms-1" Click="@(args => EditRow(_donation))" @onclick:stopPropagation="true" />
                <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Variant="Variant.Flat" Size="ButtonSize.Medium" Shade="Shade.Lighter" class="rz-my-1 rz-ms-1" Click="@(args => DeleteRow(_donation))" @onclick:stopPropagation="true" />
            </Template>
            <EditTemplate Context="_donation">
                <RadzenButton Icon="check" ButtonStyle="ButtonStyle.Success" Variant="Variant.Flat" Size="ButtonSize.Medium" Click="@((args) => SaveRow(_donation))" aria-label="Save" />
                <RadzenButton Icon="close" ButtonStyle="ButtonStyle.Light" Variant="Variant.Flat" Size="ButtonSize.Medium" class="rz-my-1 rz-ms-1" Click="@((args) => CancelEdit(_donation))" aria-label="Cancel" />
                <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Variant="Variant.Flat" Size="ButtonSize.Medium" Shade="Shade.Lighter" class="rz-my-1 rz-ms-1" Click="@(args => DeleteRow(_donation))" aria-label="Delete" />
            </EditTemplate>
        </RadzenDataGridColumn>
    </Columns>
</RadzenDataGrid>
</RadzenCard>
@code {
    RadzenDataGrid<Donation> _donationGrid;
    IEnumerable<Donation> _donations;
    IEnumerable<Donor> _donors;
    IEnumerable<DonationCategory> _categories;

    Donation _donation;

    List<Donation> DonationToInsert = new List<Donation>();
    List<Donation> DonationToUdpdate = new List<Donation>();
    List<DonorInfo> _donorInfo;
    List<CategoryInfo> _categoryInfo;

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        _donation = new Donation();
        _donations = _dbContext.Donations;

        // this allows for our drop down to have the donors and categories that were submitted already
        _categories = _dbContext.DonationCategories;
        _donors = _dbContext.Donors;
        _donorInfo = new();
        _categoryInfo = new();
        // add to list of _donorinfo and _categoryinfo
        foreach(var d in _donors)
        {
            var item = new DonorInfo()
                {
                    Id = d.DonorId,
                    FullName = d.FirstName + " " + d.LastName
                };
            _donorInfo.Add(item);
        }
        foreach (var c in _categories)
        {
            var item = new CategoryInfo()
                {
                    Id = c.DonationCategoryId ,     
                    Name = c.CategoryName
                };
            _categoryInfo.Add(item);
        }
    }
    void Reset()
    {
        DonationToInsert.Clear();
        DonationToUdpdate.Clear();
    }

    void Reset(Donation dontaion)
    {
        DonationToInsert.Remove(dontaion);
        DonationToUdpdate.Remove(dontaion);
    }

    void OnUpdateRow(Donation donation)
    {
        Reset(donation);
        _dbContext.Update(donation);
        _dbContext.SaveChanges();

        Notification(donation);
    }

    void OnCreateRow(Donation donation)
    {
        _dbContext.Add(donation);
        _dbContext.SaveChanges();
        DonationToInsert.Remove(donation);

        Notification(donation);
    }

    async Task InsertRow()
    {
        var donation = new Donation();
        DonationToInsert.Add(donation);
        await _donationGrid.InsertRow(donation);
    }

    async Task EditRow(Donation donation)
    {
        DonationToUdpdate.Add(donation);
        await _donationGrid.EditRow(donation);
    }

    async Task DeleteRow(Donation donation)  
    {
        
        Reset(donation);

        if (_donations.Contains(donation))
        {
            _dbContext.Remove(donation);
            _dbContext.SaveChanges();
            await _donationGrid.Reload();
            NotificationService.Notify(new NotificationMessage { Severity = NotificationSeverity.Warning, Detail = "Created Donation was deleted " });

        }
        else
        {
            _donationGrid.CancelEditRow(donation);
            await _donationGrid.Reload();
        }
    }

    async Task SaveRow(Donation donation)
    {
        await _donationGrid.UpdateRow(donation);
    }

    void CancelEdit(Donation donation)
    {
        Reset(donation);

        _donationGrid.CancelEditRow(donation);

        var entry = _dbContext.Entry(donation);
        if (entry.State == Microsoft.EntityFrameworkCore.EntityState.Modified)
        {
            entry.CurrentValues.SetValues(entry.OriginalValues);
            entry.State = Microsoft.EntityFrameworkCore.EntityState.Unchanged;
        }
    }

    private void Notification(Donation donation)
    {
        try
        {   // had to create a bool to check for if DonationDate and EntryDate and Amount were empty or not
            bool isNotEmpty =donation.DonationDate != default && donation.EntryDate != default &&
            donation.Amount > 0 && !string.IsNullOrEmpty(donation.PaymentMethod) &&
            !string.IsNullOrWhiteSpace(donation.ReferenceNumber) && !string.IsNullOrWhiteSpace(donation.RecordedBy) &&
            !string.IsNullOrWhiteSpace(donation.Notes);

            if(isNotEmpty)
            {
                // gives user a notification when a donor has been added to the DB
                NotificationService.Notify(new NotificationMessage { Severity = NotificationSeverity.Success, Detail = "Created Donation added " });
                // resets fields and empties input boxes
            }
            else
            {
                NotificationService.Notify(new NotificationMessage { Severity = NotificationSeverity.Warning, Summary = "Fields cannot be empty", Detail = "Make sure ALL fields have data " });
            }
        }
        catch (Exception ex)
        {
            NotificationService.Notify(new NotificationMessage { Severity = NotificationSeverity.Error, Detail = "Could not add Donation" });

        }

    }
    // to get full name of the donor
    class DonorInfo
    {
        public int Id { get; set; }
        public string FullName { get; set; }
    }
    class CategoryInfo
    {
        public int Id { get; set; }
        public string Name { get; set; }
    }

}
